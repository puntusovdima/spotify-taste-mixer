# Spotify API Credentials (from https://developer.spotify.com/dashboard)
# WARNING: Do not commit your actual .env.local file with your keys!
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Public variables (accessible on the client side in Next.js)
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
NEXT_PUBLIC_REDIRECT_URI=http://127.0.0.1:3000/auth/callback
